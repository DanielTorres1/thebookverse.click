<!-- xf-snippet code_mr0ikjpdptu9 (Snap RPS events) -->
<script>
  (function () {
    // Snapchat only supports CUSTOM_EVENT_1..5 (no arbitrary names like FB's AYRPS<N>),
    // so the AY revenue milestones are mapped to 5 Snapchat slots.
    // Fire once per session when AY predicted session revenue crosses each tier.
    var fired = {};
    var tiers = [
      { n: 5,  ev: 'CUSTOM_EVENT_1' }, // session >= 50  = 5p
      { n: 8,  ev: 'CUSTOM_EVENT_2' }, // session >= 80  = 8p
      { n: 10, ev: 'CUSTOM_EVENT_3' }, // session >= 100 = 10p
      { n: 12, ev: 'CUSTOM_EVENT_4' }, // session >= 120 = 12p
      { n: 15, ev: 'CUSTOM_EVENT_5' }  // session >= 150 = 15p
    ];
    window.addEventListener('assertive_predictedRevenue', function (e) {
      var session = e && e.data && e.data.predictedRevenueCPM && e.data.predictedRevenueCPM.session;
      if (typeof session !== 'number') return;
      if (typeof snaptr !== 'function') return; // Snap base code must be installed
      for (var i = 0; i < tiers.length; i++) {
        var t = tiers[i];
        if (session >= t.n * 10 && !fired[t.ev]) {
          fired[t.ev] = true;
          snaptr('track', t.ev);
        }
      }
    }, false);
  })();
</script>
