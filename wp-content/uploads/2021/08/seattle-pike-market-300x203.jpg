<!-- Google tag (gtag.js) for Google Ads audience collection -->
<script async src="https://www.googletagmanager.com/gtag/js?id=AW-7640402537"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'AW-7640402537');
  gtag('config', 'AW-17582068868'); // conversion account for High Value Session

  // Fire once per session after 60 seconds
  setTimeout(function () {
    try {
      if (!sessionStorage.getItem('google_ads_60_sec_audience_fired')) {
        gtag('event', 'time_on_site_60_seconds', { 'send_to': 'AW-7640402537' });
        sessionStorage.setItem('google_ads_60_sec_audience_fired', 'true');
      }
    } catch (e) {}
  }, 60000);
</script>
