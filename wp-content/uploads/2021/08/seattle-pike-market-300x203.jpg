<script>
!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
document,'script','https://connect.facebook.net/en_US/fbevents.js');
fbq('init', '2444039772641110');

(function(){
  function eid(){return 'xf-'+Date.now().toString(36)+'-'+Math.random().toString(36).slice(2,10);}
  function ck(n){var m=document.cookie.match('(?:^|;\\s*)'+n+'=([^;]+)');return m?m[1]:null;}
  function mirror(name,id,value,currency){
    try{
      var p=JSON.stringify({eventName:name,eventId:id,url:location.href,
        value:value,currency:currency,fbp:ck('_fbp'),fbc:ck('_fbc')});
      if(navigator.sendBeacon){navigator.sendBeacon('/xf-model/capi/call',p);}
      else{fetch('/xf-model/capi/call',{method:'POST',body:p,keepalive:true});}
    }catch(e){}
  }
  window.xfMeta=function(name,data){
    var id=eid();
    if(name==='PageView'){fbq('track','PageView',{},{eventID:id});}
    else{fbq('trackCustom',name,data||{},{eventID:id});}
    mirror(name,id,data&&data.value,data&&data.currency);
  };

  xfMeta('PageView');

  // AYRPS<N> once per session when AY's predicted session revenue CPM
  // crosses N*10 (same thresholds as the legacy snippet).
  var fired={};
  window.addEventListener('assertive_predictedRevenue',function(e){
    try{
      var session=e&&e.data&&e.data.predictedRevenueCPM&&e.data.predictedRevenueCPM.session;
      if(typeof session!=='number')return;
      for(var n=1;n<=30;n++){
        if(session>=n*10&&!fired[n]){
          fired[n]=1;
          xfMeta('AYRPS'+n,{value:n*0.01,currency:'GBP'});
        }
      }
    }catch(err){}
  },false);
})();
</script>
