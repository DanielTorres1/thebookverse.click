<!-- xf-snippet code_mr92abho633i (g rps5) -->
<!-- High Value Session conversion — fires once per session when AY session revenue hits 5p -->
<script>
  (function () {
    var KEY = 'google_ads_high_value_session_fired';
    window.addEventListener('assertive_predictedRevenue', function (e) {
      var session = e && e.data && e.data.predictedRevenueCPM && e.data.predictedRevenueCPM.session;
      if (typeof session !== 'number' || session < 50) return; // 50 = 5p (same n*10 scale as AYRPS)
      try {
        if (sessionStorage.getItem(KEY)) return;
        sessionStorage.setItem(KEY, '1');
      } catch (err) {}
      if (typeof gtag !== 'function') return;
      gtag('event', 'conversion', {
        'send_to': 'AW-17582068868/mY8zCLDSu8scEISp5L9B',
        'value': 0.05,
        'currency': 'GBP',
        'transaction_id': ''
      });
    });
  })();
</script>
