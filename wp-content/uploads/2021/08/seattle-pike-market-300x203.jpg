<script type="text/javascript">
setTimeout(function() {
  !function(){
    var geq=window.geq=window.geq||[];
    if(geq.initialize) return;
    if (geq.invoked){if (window.console && console.error) {console.error("GE snippet included twice.");}return;}
    geq.invoked = true;
